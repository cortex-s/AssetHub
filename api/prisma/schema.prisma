generator client {
  provider = "prisma-client-js"
  output   = "../src/lib/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  STAFF
  MEMBER
}

model Users {
  id             String  @id @db.VarChar(100) // uuid
  email          String  @unique @db.VarChar(100) // ใช้สำหรับการ login เท่านั้น
  hashedPassword String  @db.VarChar(128)
  firstname      String  @db.VarChar(50)
  lastname       String  @db.VarChar(50)
  role           Role    @default(MEMBER)
  isVerified     Boolean @default(false)

  createdAt DateTime  @default(now()) @db.DateTime(0)
  deletedAt DateTime? @db.DateTime(0)

  sessions     Sessions[]
  userVerifies UserVerify[]
  borrows      Borrows[]
}

model UserVerify {
  id         String  @id @db.VarChar(100) // uuid
  isVerified Boolean @default(false)
  token      String  @db.VarChar(500)

  userId String @db.VarChar(100)
  user   Users  @relation(fields: [userId], references: [id])

  createdAt  DateTime  @default(now()) @db.DateTime(0)
  expiresAt  DateTime  @db.DateTime(0)
  verifiedAt DateTime? @db.DateTime(0)
}

model Sessions {
  id     String @id @default(nanoid(8)) @db.VarChar(100)
  userId String @db.VarChar(100)
  user   Users  @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now()) @db.DateTime(0)
  revokedAt DateTime @db.DateTime(0)
}

model Categories {
  id          String    @id @db.VarChar(100)
  name        String    @db.VarChar(50)
  description String?   @db.VarChar(500)
  createdAt   DateTime  @default(now()) @db.DateTime(0)
  deletedAt   DateTime?

  assets Assets[]
}

enum AssetsStatus {
  available
  borrowed
  repair
  retired
}

model Assets {
  id        String @id @default(uuid()) @db.VarChar(100)
  assetCode String @unique @db.VarChar(100)
  name      String @db.VarChar(100)

  categoryId String
  category   Categories @relation(fields: [categoryId], references: [id])

  status    AssetsStatus @default(available)
  createdAt DateTime     @default(now()) @db.DateTime(0)
  updatedAt DateTime     @updatedAt @db.DateTime(0)

  borrows Borrows[]
}

model Borrows {
  id String @id @default(uuid()) @db.VarChar(100)

  assetId String
  asset   Assets @relation(fields: [assetId], references: [id])

  userId String
  user   Users  @relation(fields: [userId], references: [id])

  borrowDate DateTime  @default(now())
  dueDate    DateTime
  returnDate DateTime?

  status BorrowsStatus @default(borrowed)
}

enum BorrowsStatus {
  borrowed
  returned
  overdue
}
